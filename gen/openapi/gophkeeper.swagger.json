      "enum": [
        "ITEM_TYPE_UNSPECIFIED",
        "CREDENTIAL",
        "TEXT",
        "BINARY",
        "CARD",
        "OTP"
      ],
      "default": "ITEM_TYPE_UNSPECIFIED",
      "description": "ItemType enumerates all supported vault item categories."
