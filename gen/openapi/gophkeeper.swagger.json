        },
        "payload": {
          "type": "string",
          "format": "byte",
          "description": "payload is ChaCha20-Poly1305 encrypted JSON blob produced by the client."
        },
        "metadata": {
          "type": "string",
          "description": "metadata is plaintext free-form text (labels, tags, website)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "version": {
          "type": "string",
          "format": "int64",
          "description": "version is a monotonic counter for conflict detection during sync."
        }
      },
      "description": "VaultItem is the wire representation of a single encrypted vault entry.\nThe payload is always encrypted client-side; the server is zero-knowledge."
    },
